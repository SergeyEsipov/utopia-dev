{
  "name": "@marcosdemik/liquidglass",
  "version": "2.0.5",
  "description": "Liquid Glass UI effect for React - glassmorphism refraction with SVG filters, WebGL and GSAP animations",
  "author": "Marcos Demik <marcosdemik>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "gsap": "file:../gsap"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tsup": "^8",
    "typescript": "^5"
  },
  "keywords": [
    "liquid-glass",
    "liquidglass",
    "glassmorphism",
    "glass",
    "glass-effect",
    "refraction",
    "svg-filter",
    "webgl",
    "react",
    "react-component",
    "ui",
    "button",
    "apple",
    "ios",
    "macos",
    "chromatic-aberration",
    "gsap",
    "animation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/MarcosDemik/liquidglass"
  },
  "homepage": "https://github.com/MarcosDemik/liquidglass#readme",
  "bugs": {
    "url": "https://github.com/MarcosDemik/liquidglass/issues"
  }
}
